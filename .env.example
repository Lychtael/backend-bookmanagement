# This is a template for the .env file.
# Copy this file to a new file named .env and fill in your local values.
# DO NOT commit the .env file to Git.

# --- Database Configuration ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=perpus

# --- Flask Secret Keys ---
# You can generate these with: python -c 'import os; print(os.urandom(24).hex())'
SECRET_KEY=a_very_secret_key
JWT_SECRET_KEY=a_super_secret_jwt_key
